{
    "version": 2,
    "builds": [
        { "src": "api/index.php", "use": "vercel-php@0.6.2" },
        { "src": "public/**", "use": "@vercel/static" }
    ],
    "routes": [
        { "src": "/build/(.*)", "dest": "/public/build/$1" },
        { "src": "/manifest.json", "dest": "/public/manifest.json" },
        { "src": "/sw.js", "dest": "/public/sw.js" },
        { "src": "/(.*)", "dest": "/api/index.php" }
    ]
}